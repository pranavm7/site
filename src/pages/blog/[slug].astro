---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Tell Astro which slugs to pre-render
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props:  { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Format date: "12 March 2026"
const dateStr = post.data.date.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});
---

<BaseLayout title={post.data.title} currentPath={`/blog/${post.slug}`}>
<style>
  /* ── Prose wrapper ── */
  .post-page { padding: 32px 40px; max-width: 800px; }

  .back-link {
    display: inline-flex; align-items: center; gap: 6px;
    color: var(--text-muted); font-size: 13px;
    text-decoration: none; margin-bottom: 24px;
  }
  .back-link:hover { color: var(--accent); }

  .post-header {
    border-bottom: 1px solid var(--border);
    padding-bottom: 20px; margin-bottom: 32px;
  }
  .post-header h1 {
    font-size: 22px; font-weight: 700; line-height: 1.3; margin-bottom: 10px;
  }
  .post-meta { display: flex; gap: 10px; align-items: center; color: var(--text-muted); font-size: 12px; flex-wrap: wrap; }
  .post-tag {
    border: 1px solid var(--accent2); color: var(--accent2);
    padding: 1px 8px; font-size: 11px;
  }

  /* ── Markdown content ── */
  .post-body { font-size: 14px; line-height: 1.85; color: var(--text); }

  .post-body :global(h2) {
    font-size: 17px; font-weight: 700; margin: 32px 0 12px;
    color: var(--accent);
    padding-bottom: 6px; border-bottom: 1px solid var(--border);
  }
  .post-body :global(h3) {
    font-size: 15px; font-weight: 700; margin: 22px 0 10px;
    color: var(--accent2);
  }
  .post-body :global(h4) {
    font-size: 14px; font-weight: 700; margin: 18px 0 8px;
    color: var(--text);
  }
  .post-body :global(p) { margin-bottom: 16px; }

  .post-body :global(ul), .post-body :global(ol) {
    margin: 0 0 16px 22px;
  }
  .post-body :global(li) { margin-bottom: 6px; }

  /* Inline code */
  .post-body :global(:not(pre) > code) {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    padding: 1px 6px;
    font-size: 12px;
    color: var(--green);
    border-radius: 2px;
  }

  /* Code blocks */
  .post-body :global(pre) {
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    padding: 16px 20px;
    overflow-x: auto;
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .post-body :global(pre code) {
    background: none; border: none; padding: 0;
    color: var(--text); font-size: 13px;
  }

  /* Blockquote */
  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent2);
    padding: 8px 16px;
    margin: 0 0 16px;
    color: var(--text-muted);
    background: var(--bg-alt);
    font-style: italic;
  }
  .post-body :global(blockquote p) { margin-bottom: 0; }

  /* Tables */
  .post-body :global(table) {
    width: 100%; border-collapse: collapse;
    margin-bottom: 20px; font-size: 13px;
  }
  .post-body :global(th) {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    padding: 6px 12px;
    text-align: left; color: var(--accent);
    font-weight: 700;
  }
  .post-body :global(td) {
    border: 1px solid var(--border);
    padding: 6px 12px;
    color: var(--text-muted);
  }
  .post-body :global(tr:hover td) { background: var(--bg-alt); color: var(--text); }

  /* Strong / em */
  .post-body :global(strong) { color: var(--yellow); font-weight: 700; }
  .post-body :global(em)     { color: var(--text-muted); font-style: italic; }

  /* Links */
  .post-body :global(a) { color: var(--accent); }
  .post-body :global(a:hover) { color: var(--accent2); }

  /* HR */
  .post-body :global(hr) { border: none; border-top: 1px solid var(--border); margin: 28px 0; }

  /* ── Optional TOC ── */
  .toc {
    border: 1px solid var(--border); background: var(--bg-alt);
    padding: 14px 18px; margin-bottom: 28px; font-size: 13px;
  }
  .toc-title { color: var(--text-muted); font-size: 11px; margin-bottom: 8px; }
  .toc-list { list-style: none; margin: 0; padding: 0; }
  .toc-item { margin-bottom: 4px; }
  .toc-item a { color: var(--text-muted); text-decoration: none; }
  .toc-item a:hover { color: var(--accent); }
  .toc-item.h3 { padding-left: 16px; font-size: 12px; }

  @media (max-width: 768px) {
    .post-page { padding: 20px 16px; }
  }
</style>

<div class="post-page">
  <a class="back-link" href="/blog">← back to blog</a>

  <div class="post-header">
    <h1>{post.data.title}</h1>
    <div class="post-meta">
      <span>{dateStr}</span>
      {post.data.tags.map(tag => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
  </div>

  <!-- Table of Contents (auto-generated from headings) -->
  {headings.length > 0 && (
    <nav class="toc">
      <div class="toc-title">// Contents</div>
      <ul class="toc-list">
        {headings.filter(h => h.depth <= 3).map(h => (
          <li class={`toc-item ${h.depth === 3 ? 'h3' : ''}`}>
            <a href={`#${h.slug}`}>{h.depth === 3 ? '└ ' : ''}{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <div class="post-body">
    <Content />
  </div>
</div>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
const page = Astro.url.pathname.split("/").filter(Boolean).pop();
const titles: Record<string, string> = {
    experience: "💼 Experience",
    skills: "🛠️ Skills",
    projects: "🚀 Projects",
    hobbies: "🎵 Hobbies",
    achievements: "🏆 Achievements",
    contact: "📧 Contact",
};
const title = titles[page ?? ""] ?? page ?? "";
---

<BaseLayout title={title} currentPath={`/cv/${page}`}>
    <div style="padding:32px 40px; max-width:900px;">
        <a
            href="/cv"
            style="display:inline-flex;align-items:center;gap:6px;color:var(--text-muted);font-size:13px;text-decoration:none;margin-bottom:24px;"
            onmouseover="this.style.color='var(--accent)'"
            onmouseout="this.style.color='var(--text-muted)'">← back to cv</a
        >
        <h1
            style="font-size:22px;font-weight:700;color:var(--text);margin-bottom:24px;"
        >
            {title}
        </h1>
        <div
            style="border:1px solid var(--border);background:var(--bg-alt);padding:20px 24px;color:var(--text-muted);font-size:13px;line-height:1.8;"
        >
            <p>📝 This section is under construction. Content coming soon.</p>
        </div>
    </div>
</BaseLayout>
